# =============================================================================
# PROPESQI RAG Chatbot — AWS / Gemini-only Environment Variables Template
# =============================================================================
# Used with docker-compose.aws.yml. No Ollama service in this mode — LLM and
# dense embeddings are both served by the Gemini API.
#
# Copy this file to `.env` and fill in real values before running:
#   cp .env.aws.example .env
#
# SECURITY RULES:
#   - Never commit `.env` to version control (it is in .gitignore).
#   - Replace every CHANGE_ME placeholder with strong, unique values.
#   - Rotate SECRET_KEY if it is ever exposed.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_USER=propesqi
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password_here
POSTGRES_DB=propesqi_db

# Limited-privilege application role — the backend connects as this user.
PROPESQI_APP_PASSWORD=CHANGE_ME_strong_app_db_password_here

# Async SQLAlchemy connection URL — uses the limited-privilege app role.
DATABASE_URL=postgresql+asyncpg://propesqi_app:CHANGE_ME_strong_app_db_password_here@postgres:5432/propesqi_db

# First admin login, created automatically on first startup.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_here


# -----------------------------------------------------------------------------
# Qdrant Vector Store
# -----------------------------------------------------------------------------

QDRANT_URL=http://qdrant:6333

# MINIMUM LENGTH: 32 characters.  Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
QDRANT_API_KEY=CHANGE_ME_strong_qdrant_api_key_here_000000000000000000000


# -----------------------------------------------------------------------------
# Gemini — REQUIRED in this mode (LLM + embeddings)
# -----------------------------------------------------------------------------

# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=CHANGE_ME_google_api_key_here

# rag_config in the database is what actually selects the provider/model at
# runtime (adjustable via the admin panel without restarting). A fresh
# database is seeded with llm_provider=gemini / embedding_provider=gemini
# already (see init/01_schema.sql). This env var is only the Gemini
# credential — it is not itself a provider switch.


# -----------------------------------------------------------------------------
# LLMWhisperer — cloud OCR for scanned PDFs
# -----------------------------------------------------------------------------

# Required to process scanned PDFs. No local Tesseract/OpenCV runs in this
# mode — OCR is entirely offloaded to the LLMWhisperer API.
# Get a key at https://unstract.com/llmwhisperer/
LLMWHISPERER_API_KEY=


# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# MINIMUM LENGTH: 32 characters.  Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_at_least_32_chars_long_random_hex_secret_key_here_000000
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# CORS — Allowed Frontend Origins
# -----------------------------------------------------------------------------

# In production, restrict to the actual hostname serving the frontend.
# Example: https://chatbot.propesqi.ufpi.br
ALLOWED_ORIGINS=https://CHANGE_ME.example.com


# -----------------------------------------------------------------------------
# Frontend (Vite build-time variable)
# -----------------------------------------------------------------------------

# nginx inside the frontend container proxies /api/* to backend:8000, so the
# browser only ever talks to the same origin. Leave as /api unless the
# backend is exposed on a different domain.
VITE_API_URL=/api
