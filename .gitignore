# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.aws.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
.venv-*/
venv/
env/
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
*.cover
.hypothesis/
nosetests.xml
coverage.xml
*.log

# ---------------------------------------------------------------------------
# Node / Frontend
# ---------------------------------------------------------------------------
node_modules/
dist/
.vite/
coverage/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
# Never commit real docker-compose overrides with secrets
docker-compose.override.yml

# ---------------------------------------------------------------------------
# Uploads / data
# ---------------------------------------------------------------------------
uploads/
*.pdf
*.docx
*.odt

# ---------------------------------------------------------------------------
# IDEs / editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# OS
# ---------------------------------------------------------------------------
.DS_Store
ehthumbs.db
desktop.ini

# Fine-tuned model weights (large binary — store outside git)
backend/models/
