# =============================================================================
# PROPESQI RAG Chatbot — Environment Variables Template
# =============================================================================
# Copy this file to `.env` and fill in real values before running:
#   cp .env.example .env
#
# SECURITY RULES:
#   - Never commit `.env` to version control (it is in .gitignore).
#   - Replace every CHANGE_ME placeholder with strong, unique values.
#   - Rotate SECRET_KEY if it is ever exposed.
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Database superuser credentials — used ONLY for init scripts and migrations
POSTGRES_USER=propesqi
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password_here

# Database name created on first startup
POSTGRES_DB=propesqi_db

# Limited-privilege application role — the backend connects as this user.
# It has SELECT/INSERT/UPDATE/DELETE on application tables only (no DDL).
# Do NOT use POSTGRES_USER credentials in DATABASE_URL.
PROPESQI_APP_PASSWORD=CHANGE_ME_strong_app_db_password_here

# Async SQLAlchemy connection URL — uses the limited-privilege app role.
# Host "postgres" resolves to the postgres container on propesqi-net.
DATABASE_URL=postgresql+asyncpg://propesqi_app:CHANGE_ME_strong_app_db_password_here@postgres:5432/propesqi_db

# First admin login, created automatically on first startup by
# init/02_seed_admin.sh (skipped if a user with this email already exists).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_strong_admin_password_here


# -----------------------------------------------------------------------------
# Qdrant Vector Store
# -----------------------------------------------------------------------------

# Internal service URL — do not change unless you rename the service
QDRANT_URL=http://qdrant:6333

# API key for Qdrant authentication.
# Set on the qdrant service (QDRANT__SERVICE__API_KEY) and passed to the backend.
# MINIMUM LENGTH: 32 characters.  Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
QDRANT_API_KEY=CHANGE_ME_strong_qdrant_api_key_here_000000000000000000000


# -----------------------------------------------------------------------------
# Ollama — local LLM & embedding server
# -----------------------------------------------------------------------------

# Internal service URL — do not change unless you rename the service
OLLAMA_BASE_URL=http://ollama:11434


# -----------------------------------------------------------------------------
# Proprietary LLM API keys (optional — only required when llm_provider != 'local')
# -----------------------------------------------------------------------------

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=


# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------

# SECRET_KEY: used to sign JWT tokens.
# MINIMUM LENGTH: 32 characters.  Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_at_least_32_chars_long_random_hex_secret_key_here_000000

# Signing algorithm — HS256 is recommended for symmetric signing
ALGORITHM=HS256

# Access token lifetime in minutes (short-lived, e.g. 60 = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token lifetime in days (longer-lived, e.g. 7 days)
REFRESH_TOKEN_EXPIRE_DAYS=7


# -----------------------------------------------------------------------------
# CORS — Allowed Frontend Origins
# -----------------------------------------------------------------------------

# Comma-separated list of allowed origins for the FastAPI CORS middleware.
# In production, restrict to the actual hostname/IP serving the frontend.
# Example (production): https://chatbot.propesqi.ufpi.br
ALLOWED_ORIGINS=http://localhost:3000


# -----------------------------------------------------------------------------
# Frontend (Vite build-time variable)
# -----------------------------------------------------------------------------

# Public URL the **browser** uses to reach the backend API.
# The frontend container runs nginx which proxies /api/* to backend:8000
# on the internal Docker network.  Set VITE_API_URL to the nginx-relative
# prefix so the browser always calls the same origin (port 3000) and
# never needs direct access to the unpublished backend port.
#
# LOCAL DEVELOPMENT (default):  VITE_API_URL=/api
# PRODUCTION (reverse proxy):   VITE_API_URL=/api   (same — nginx handles it)
# EXTERNAL BACKEND (no nginx):  VITE_API_URL=https://api.example.com
VITE_API_URL=/api
